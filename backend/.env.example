# Copy this file to .env and fill in your actual values.
# DO NOT commit the real .env file.

# Server
PORT=4100

# MongoDB connection string (get from MongoDB Atlas or local)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# JWT signing secret (use a long random string, e.g. from `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Gmail credentials for OTP emails (use App Password, not login password)
# Get App Password at https://myaccount.google.com/apppasswords (requires 2FA enabled)
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-16-char-app-password

# --- Cloud LLM (optional; offline KB still works without these) ---
# Gemini is preferred when GEMINI_API_KEY is present; otherwise DeepSeek is used.
# REQUIRED on a hosted deployment for the IDE chat to answer KB-miss questions —
# set this in the host's environment-variable dashboard, NOT in a committed file.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# DeepSeek fallback (used only when GEMINI_API_KEY is empty). https://platform.deepseek.com
DEEPSEEK_API_KEY=
